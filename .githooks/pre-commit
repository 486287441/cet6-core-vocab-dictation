#!/bin/sh
# 若暂存了除 README.md 以外的文件，则 README.md 也必须出现在暂存区。
STAGED=$(git diff --cached --name-only)
[ -z "$STAGED" ] && exit 0

NON_README=$(printf '%s\n' "$STAGED" | grep -v '^README\.md$' | grep -c . || true)
[ "$NON_README" -eq 0 ] && exit 0

printf '%s\n' "$STAGED" | grep -q '^README\.md$' || {
  echo "pre-commit: 提交代码或文档时须同时更新 README.md"
  echo "  请在 README「更新记录」中追加一条，并 git add README.md"
  exit 1
}

exit 0
